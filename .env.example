# ─── 0x API ────────────────────────────────────────────────────────────────────
# Get a key at https://dashboard.0x.org
ZERO_X_API_KEY=your_0x_api_key_here

# ─── Wallet ────────────────────────────────────────────────────────────────────
# EVM address that receives x402 payments
PAYMENT_RECIPIENT_ADDRESS=0xYourEVMAddressHere

# ─── x402 Facilitator ──────────────────────────────────────────────────────────
# Testnet uses https://x402.org/facilitator automatically (no config needed)
# Mainnet uses https://api.cdp.coinbase.com/platform/v2/x402 — requires CDP keys below

# CDP keys (only needed for mainnet — leave blank on testnet)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ─── Network ───────────────────────────────────────────────────────────────────
# eip155:84532  = Base Sepolia (testnet)
# eip155:8453   = Base mainnet
# eip155:137    = Polygon mainnet
X402_NETWORK=eip155:84532

# ─── Pricing (USD) ─────────────────────────────────────────────────────────────
PRICE_INDICATIVE_PRICE=0.001
PRICE_FIRM_QUOTE=0.01

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4021
NODE_ENV=development

# ─── Client test (only for test/client.ts) ────────────────────────────────────
# A funded testnet private key — NEVER commit a real key
CLIENT_PRIVATE_KEY=0xYourTestnetPrivateKeyHere
